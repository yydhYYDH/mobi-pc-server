From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: yydh <yydh@example.com>
Date: Mon, 29 Jun 2026 18:05:00 +0800
Subject: [PATCH] Fix Windows ERROR macro conflict in log utils

Windows headers can define ERROR as a macro. When that macro is visible
before log_utils.hpp is parsed, it rewrites the LogLevel::ERROR enum
member and breaks MSVC compilation. Undefine the macro before declaring
the downloader logging namespace.
---
 apps/frameworks/model_downloader/cpp/include/log_utils.hpp | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/apps/frameworks/model_downloader/cpp/include/log_utils.hpp b/apps/frameworks/model_downloader/cpp/include/log_utils.hpp
index 695cabe8..1d609d74 100644
--- a/apps/frameworks/model_downloader/cpp/include/log_utils.hpp
+++ b/apps/frameworks/model_downloader/cpp/include/log_utils.hpp
@@ -10,6 +10,10 @@
 #include <sstream>
 #include <memory>
 
+#ifdef ERROR
+#undef ERROR
+#endif
+
 namespace mnn::downloader {
 
 // Terminal color constants for colored logging
-- 
2.40.1.windows.1

