From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Siming Chen <867965859@qq.com>
Date: Thu, 11 Jun 2026 00:00:00 +0800
Subject: [PATCH] Link CUDA backend for llm_bench

When MNN is built with CUDA, llm_bench can still fall back to CPU if
libMNN_Cuda_Main.so is not recorded as a needed library for the
benchmark executable. Link the CUDA backend with --no-as-needed and add
an rpath to the backend output directory so CUDA backend registration
runs when llm_bench starts.
---
 transformers/llm/engine/tools/CMakeLists.txt | 17 +++++++++++++++++
 1 file changed, 17 insertions(+)

diff --git a/transformers/llm/engine/tools/CMakeLists.txt b/transformers/llm/engine/tools/CMakeLists.txt
index 559efa39..1e635aa7 100644
--- a/transformers/llm/engine/tools/CMakeLists.txt
+++ b/transformers/llm/engine/tools/CMakeLists.txt
@@ -4,6 +4,23 @@ add_executable(ppl_eval ${CMAKE_CURRENT_LIST_DIR}/ppl_eval.cpp)
 add_executable(generateLlmIO ${CMAKE_CURRENT_LIST_DIR}/generateLlmIO.cpp)
 target_link_libraries(llm_bench ${LLM_DEPS})
 target_include_directories(llm_bench PRIVATE ${CMAKE_CURRENT_SOURCE_DIR}/tools/cpp)
+
+# Link optional CUDA backend when the main MNN build produced it.
+# Without a DT_NEEDED entry for libMNN_Cuda_Main.so, llm_bench -a cuda can
+# silently fall back to CPU because the CUDA backend registration code never
+# runs in the benchmark process.
+set(LLM_BENCH_CUDA_BACKEND_LIBRARY "${CMAKE_BINARY_DIR}/source/backend/cuda/libMNN_Cuda_Main.so")
+if(MNN_CUDA AND EXISTS "${LLM_BENCH_CUDA_BACKEND_LIBRARY}")
+    if(UNIX AND NOT APPLE)
+        target_link_libraries(llm_bench PRIVATE "-Wl,--no-as-needed" "${LLM_BENCH_CUDA_BACKEND_LIBRARY}" "-Wl,--as-needed")
+    else()
+        target_link_libraries(llm_bench PRIVATE "${LLM_BENCH_CUDA_BACKEND_LIBRARY}")
+    endif()
+    set_target_properties(llm_bench PROPERTIES
+        BUILD_RPATH "${CMAKE_BINARY_DIR}/source/backend/cuda"
+        INSTALL_RPATH "${CMAKE_BINARY_DIR}/source/backend/cuda"
+    )
+endif()
 target_link_libraries(generateLlmIO ${LLM_DEPS})
 target_link_libraries(quantize_llm ${LLM_DEPS})
 target_include_directories(generateLlmIO PRIVATE ${CMAKE_CURRENT_LIST_DIR}/../src)
