From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: yydh <yydh@example.com>
Date: Wed, 17 Jun 2026 16:20:00 +0800
Subject: [PATCH] Link CUDA backend for llm_demo

When MNN is built with CUDA, llm_demo can still fall back to CPU if the
CUDA runtime registration code never runs in the demo process. Add the
CUDA Register.cpp source to llm_demo, link libMNN_Cuda_Main.so with
--no-as-needed, and add an rpath to the backend output directory.
---
 transformers/llm/engine/CMakeLists.txt | 21 +++++++++++++++++++++
 1 file changed, 21 insertions(+)

diff --git a/transformers/llm/engine/CMakeLists.txt b/transformers/llm/engine/CMakeLists.txt
index 00000000..00000000 100644
--- a/transformers/llm/engine/CMakeLists.txt
+++ b/transformers/llm/engine/CMakeLists.txt
@@ -86,6 +86,18 @@ ENDIF()
 
 if(MNN_LLM_BUILD_DEMO)
     add_executable(llm_demo ${CMAKE_CURRENT_LIST_DIR}/demo/llm_demo.cpp)
+    set(LLM_DEMO_CUDA_BACKEND_LIBRARY "${CMAKE_BINARY_DIR}/source/backend/cuda/libMNN_Cuda_Main.so")
+    set(LLM_DEMO_CUDA_REGISTER_SOURCE "${CMAKE_CURRENT_LIST_DIR}/../../../source/backend/cuda/Register.cpp")
+    if(MNN_CUDA AND EXISTS "${LLM_DEMO_CUDA_BACKEND_LIBRARY}" AND EXISTS "${LLM_DEMO_CUDA_REGISTER_SOURCE}")
+        find_package(CUDAToolkit QUIET)
+        target_sources(llm_demo PRIVATE "${LLM_DEMO_CUDA_REGISTER_SOURCE}")
+        target_include_directories(llm_demo PRIVATE
+            ${CMAKE_CURRENT_LIST_DIR}/../../../source
+            ${CMAKE_CURRENT_LIST_DIR}/../../../source/backend/cuda
+            ${CUDAToolkit_INCLUDE_DIRS}
+        )
+    endif()
     add_executable(embedding_demo ${CMAKE_CURRENT_LIST_DIR}/demo/embedding_demo.cpp)
     add_executable(reranker_demo ${CMAKE_CURRENT_LIST_DIR}/demo/reranker_demo.cpp)
     add_executable(rollback_demo ${CMAKE_CURRENT_LIST_DIR}/demo/rollback_demo.cpp)
@@ -95,6 +107,18 @@ if(MNN_LLM_BUILD_DEMO)
 
     include(${CMAKE_CURRENT_LIST_DIR}/tools/CMakeLists.txt)
     target_link_libraries(llm_demo ${LLM_DEPS})
+    set(LLM_DEMO_CUDA_BACKEND_LIBRARY "${CMAKE_BINARY_DIR}/source/backend/cuda/libMNN_Cuda_Main.so")
+    if(MNN_CUDA AND EXISTS "${LLM_DEMO_CUDA_BACKEND_LIBRARY}")
+        if(UNIX AND NOT APPLE)
+            target_link_libraries(llm_demo "-Wl,--no-as-needed" "${LLM_DEMO_CUDA_BACKEND_LIBRARY}" "-Wl,--as-needed")
+        else()
+            target_link_libraries(llm_demo "${LLM_DEMO_CUDA_BACKEND_LIBRARY}")
+        endif()
+        set_target_properties(llm_demo PROPERTIES
+            BUILD_RPATH "${CMAKE_BINARY_DIR}/source/backend/cuda"
+            INSTALL_RPATH "${CMAKE_BINARY_DIR}/source/backend/cuda"
+        )
+    endif()
     target_link_libraries(embedding_demo ${LLM_DEPS})
     target_link_libraries(reranker_demo ${LLM_DEPS})
     target_link_libraries(rollback_demo ${LLM_DEPS})
