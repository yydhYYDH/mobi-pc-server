From 44cbb9c0aff26877367290e6b7e81ec0f384bc46 Mon Sep 17 00:00:00 2001
From: Siming Chen <867965859@qq.com>
Date: Wed, 10 Jun 2026 18:16:37 +0800
Subject: [PATCH] Enable CUDA backend for mnncli serve

---
 apps/mnncli/CMakeLists.txt                    | 29 +++++++++++++++++++
 apps/mnncli/build.sh                          |  4 ++-
 apps/mnncli/include/mnncli_server.hpp         |  7 ++++-
 .../src/handlers/serve_command_handler.cpp    |  2 +-
 apps/mnncli/src/mnncli_server.cpp             |  4 +--
 5 files changed, 41 insertions(+), 5 deletions(-)

diff --git a/apps/mnncli/CMakeLists.txt b/apps/mnncli/CMakeLists.txt
index f148fa82..13b0bfce 100644
--- a/apps/mnncli/CMakeLists.txt
+++ b/apps/mnncli/CMakeLists.txt
@@ -106,6 +106,17 @@ set(MNNCLI_SOURCES
     ${CMAKE_CURRENT_LIST_DIR}/src/handlers/info_command_handler.cpp
 )
 
+set(MNN_CUDA_BACKEND_LIBRARY "${MNN_BUILD_DIR}/source/backend/cuda/libMNN_Cuda_Main.so")
+set(MNN_CUDA_REGISTER_SOURCE "${MNN_SOURCE_DIR}/source/backend/cuda/Register.cpp")
+if(EXISTS "${MNN_CUDA_BACKEND_LIBRARY}" AND EXISTS "${MNN_CUDA_REGISTER_SOURCE}")
+    message(STATUS "Found MNN CUDA backend: ${MNN_CUDA_BACKEND_LIBRARY}")
+    find_package(CUDAToolkit QUIET)
+    if(CUDAToolkit_FOUND)
+        message(STATUS "Found CUDA Toolkit includes: ${CUDAToolkit_INCLUDE_DIRS}")
+    endif()
+    list(APPEND MNNCLI_SOURCES "${MNN_CUDA_REGISTER_SOURCE}")
+endif()
+
 if(CMAKE_SYSTEM_NAME STREQUAL "Android")
     list(APPEND MNNCLI_SOURCES ${CMAKE_CURRENT_LIST_DIR}/src/AndroidVideoDecoder.cpp)
 endif()
@@ -115,6 +126,11 @@ add_executable(mnncli ${MNNCLI_SOURCES})
 target_include_directories(mnncli PRIVATE
     ${CMAKE_CURRENT_LIST_DIR}/include
     ${MNN_SOURCE_DIR}/include
+    ${MNN_SOURCE_DIR}/schema/current
+    ${MNN_SOURCE_DIR}/source
+    ${MNN_SOURCE_DIR}/source/backend/cuda
+    ${MNN_SOURCE_DIR}/3rd_party/flatbuffers/include
+    ${CUDAToolkit_INCLUDE_DIRS}
     ${MNN_SOURCE_DIR}/transformers/llm/engine/include
     ${MNN_SOURCE_DIR}/transformers/llm/engine/src
     ${MNN_SOURCE_DIR}/3rd_party
@@ -127,6 +143,19 @@ target_include_directories(mnncli PRIVATE
 # Link to pre-built MNN static library
 target_link_libraries(mnncli PRIVATE ${MNN_LIBRARY})
 
+# Link optional CUDA backend when the parent MNN build produced it.
+if(EXISTS "${MNN_CUDA_BACKEND_LIBRARY}")
+    if(UNIX AND NOT APPLE)
+        target_link_libraries(mnncli PRIVATE "-Wl,--no-as-needed" "${MNN_CUDA_BACKEND_LIBRARY}" "-Wl,--as-needed")
+    else()
+        target_link_libraries(mnncli PRIVATE "${MNN_CUDA_BACKEND_LIBRARY}")
+    endif()
+    set_target_properties(mnncli PROPERTIES
+        BUILD_RPATH "${MNN_BUILD_DIR}/source/backend/cuda"
+        INSTALL_RPATH "${MNN_BUILD_DIR}/source/backend/cuda"
+    )
+endif()
+
 # Link model downloader
 target_link_libraries(mnncli PRIVATE mnn_model_downloader)
 
diff --git a/apps/mnncli/build.sh b/apps/mnncli/build.sh
index 6a608745..c5fb8f93 100755
--- a/apps/mnncli/build.sh
+++ b/apps/mnncli/build.sh
@@ -63,6 +63,8 @@ if [ "$OS_NAME" == "Darwin" ]; then
     CMAKE_ARGS+=("-DMNN_METAL=ON")
 elif [ "$OS_NAME" == "Linux" ]; then
     CMAKE_ARGS+=("-DMNN_OPENCL=ON") # Enable OpenCL for Linux if available/needed, otherwise can be omitted
+    CMAKE_ARGS+=("-DMNN_CUDA=ON")
+    CMAKE_ARGS+=("-DMNN_CUDA_NATIVE_ARCH=ON")
     # You might want to add -DMNN_VULKAN=ON if Vulkan is needed
 else
     echo -e "${YELLOW}Warning: Unknown OS $OS_NAME, using default configuration${NC}"
@@ -146,4 +148,4 @@ else
     exit 1
 fi
 
-echo -e "${GREEN}Build completed successfully!${NC}"
\ No newline at end of file
+echo -e "${GREEN}Build completed successfully!${NC}"
diff --git a/apps/mnncli/include/mnncli_server.hpp b/apps/mnncli/include/mnncli_server.hpp
index edd270b9..54b1e7d2 100644
--- a/apps/mnncli/include/mnncli_server.hpp
+++ b/apps/mnncli/include/mnncli_server.hpp
@@ -618,7 +618,12 @@ class MnncliServer {
 </body>
 </html>
     )""";
-    void Start(MNN::Transformer::Llm* llm, bool is_r1, const std::string& host = "127.0.0.1", int port = 8000);
+    void Start(
+        MNN::Transformer::Llm* llm,
+        bool is_r1,
+        const std::string& model_name,
+        const std::string& host = "127.0.0.1",
+        int port = 8000);
     bool is_r1_{false};
 private:
   void Answer(MNN::Transformer::Llm* llm, const json &messages, std::function<void(const std::string&)> on_result);
diff --git a/apps/mnncli/src/handlers/serve_command_handler.cpp b/apps/mnncli/src/handlers/serve_command_handler.cpp
index 3cc659dd..3daf49a4 100644
--- a/apps/mnncli/src/handlers/serve_command_handler.cpp
+++ b/apps/mnncli/src/handlers/serve_command_handler.cpp
@@ -142,7 +142,7 @@ int ServeCommandHandler::Handle(const ParsedCommand& cmd) {
 
     // Start HTTP server (blocking call)
     MnncliServer server;
-    server.Start(llm.get(), is_r1, host, port);
+    server.Start(llm.get(), is_r1, model_name, host, port);
 
     return 0;
 }
diff --git a/apps/mnncli/src/mnncli_server.cpp b/apps/mnncli/src/mnncli_server.cpp
index a49988a8..5e99723c 100644
--- a/apps/mnncli/src/mnncli_server.cpp
+++ b/apps/mnncli/src/mnncli_server.cpp
@@ -221,7 +221,7 @@ void AllowCors(httplib::Response& res) {
     res.set_header("Access-Control-Allow-Headers",  "Content-Type, Authorization");
 }
 
-void MnncliServer::Start(MNN::Transformer::Llm* llm, bool is_r1, const std::string& host, int port) {
+void MnncliServer::Start(MNN::Transformer::Llm* llm, bool is_r1, const std::string& model_name, const std::string& host, int port) {
     this->is_r1_ = is_r1;
     // Create a server instance
     httplib::Server server;
@@ -245,7 +245,7 @@ void MnncliServer::Start(MNN::Transformer::Llm* llm, bool is_r1, const std::stri
         {"object", "list"},
         {"data", json::array({
           {
-            {"id", "ModelScope/MNN/Qwen2.5-0.5B-Instruct"},
+            {"id", model_name},
             {"object", "model"},
             {"created", static_cast<int>(time(nullptr))},
             {"owned_by", "mnn"}
-- 
